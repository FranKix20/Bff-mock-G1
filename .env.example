# --- General ---
NODE_ENV=development
PORT=3001
# Origen adicional permitido para CORS (además de localhost)
FRONTEND_URL=

# --- Persistencia (Supabase Postgres) ---
# Si se dejan vacías, el BFF opera en modo degradado (memoria local)
# y lo reporta en GET /health como "in-memory (degraded)".
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# --- Integraciones con otros grupos ---
# Si una URL no está configurada, el BFF cae automáticamente a un
# mock interno para esa integración (X-Data-Source: mock).

# Grupo 2 - Identidad y sesiones
AUTH_SERVICE_URL=

# Grupo 3 - Catálogo de productos
PRODUCTS_SERVICE_URL=

# Grupo 4 - Carro
CART_SERVICE_URL=

# Grupo 4/5 - Checkout (si exponen un servicio separado del de carro)
CHECKOUT_SERVICE_URL=

# Grupo 5 - Pedidos
ORDERS_SERVICE_URL=

# Grupo 9 - Notificaciones
NOTIFICATIONS_SERVICE_URL=

# Grupo 11 - Chatbot
CHATBOT_SERVICE_URL=
CHATBOT_API_KEY=
